rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
            && data.email is string && data.email.size() > 0
            && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256))
            && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
    }

    // Chat Sessions
    match /users/{userId}/sessions/{sessionId} {
      function isValidSession(data) {
        return data.id == sessionId && data.userId == userId
            && data.title is string && data.title.size() <= 512
            && data.lastUpdated is string;
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSession(request.resource.data);
      allow update: if isOwner(userId) && isValidSession(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'lastUpdated', 'systemPrompt', 'summary']);
      allow delete: if isOwner(userId);

      // Messages (subcollection)
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.id == messageId && data.sessionId == sessionId && data.userId == userId
              && data.role in ['user', 'assistant']
              && data.content is string && data.content.size() <= 32768
              && data.timestamp is string;
        }

        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
